# D-Vision Backend URL (FastAPI server running dashboard.py)
# Use your machine's LAN IP for mobile testing (not localhost)
API_BASE_URL=http://192.168.1.100:8000

# MongoDB Atlas (if connecting directly instead of via backend)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=dvision
