{
  "expo": {
    "name": "Vela Vision",
    "slug": "VVision-App",
    "scheme": "vela",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.velavision.caregiver",
      "associatedDomains": [
        "applinks:velavision.org"
      ],
      "buildNumber": "12",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Vela Vision uses the microphone for voice check-ins with your care team.",
        "NSMotionUsageDescription": "Vela uses motion data to detect activity patterns for your care team.",
        "NSLocationWhenInUseUsageDescription": "Vela uses your location to let your care team know if you leave your safe zone.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Vela uses your location in the background to alert your care team if you leave your safe zone.",
        "UIBackgroundModes": [
          "fetch"
        ],
        "NSHealthShareUsageDescription": "Vela shares general wellness trends (steps, heart rate, sleep, activity) with your care team. Not for medical or diagnostic use.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIDesignRequiresCompatibility": true
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0e1a"
      },
      "package": "com.velavision.caregiver"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": "https://vvision-app.onrender.com",
      "supabaseUrl": "https://xqqihmzbbqztfrvsbsnx.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhxcWlobXpiYnF6dGZydnNic254Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4OTgzMjAsImV4cCI6MjA5MDQ3NDMyMH0.bstOKmv5I8kLmfKOtT2Ll58muLw4anhitQflzD1Iz4Y",
      "eas": {
        "projectId": "3c37394e-ce0d-4209-ae60-662d0bcac673"
      }
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "Vela uses your health data (steps, heart rate, sleep, activity) to help your care team monitor your wellbeing."
        }
      ],
      "expo-secure-store"
    ],
    "owner": "haadi.siddiqui"
  }
}
